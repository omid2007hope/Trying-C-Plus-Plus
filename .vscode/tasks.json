{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++ (MSVC)",
      "type": "shell",
      "command": "call \"C:\\Program Files (x86)\\Microsoft Visual Studio\\18\\BuildTools\\VC\\Auxiliary\\Build\\vcvars64.bat\" && cl.exe /EHsc \"${file}\" /Fe:\"${fileDirname}\\${fileBasenameNoExtension}.exe\"",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
